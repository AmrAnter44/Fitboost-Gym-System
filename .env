# SQLite Database with WAL mode for better concurrent performance
# timeout: 20 seconds for database operations
# journal_mode=WAL: Write-Ahead Logging for better concurrency
DATABASE_URL="file:/Users/amranter200444/Desktop/Gyms/More/Fitboost-System/prisma/gym.db?connection_limit=1&pool_timeout=20&journal_mode=WAL"

# JWT Secret - IMPORTANT: Change this in production!
JWT_SECRET="gym-secret-key-12345-CHANGE-THIS-IN-PRODUCTION"

# Network Settings
PORT=4001
HOSTNAME=0.0.0.0

# Environment (development/production)
NODE_ENV=development

# Public URL - غيّره للـ subdomain بتاعك
# بعد ما تخلص الإعداد، غيّره لـ:
NEXT_PUBLIC_APP_URL=http://localhost:4001

# Website URL - يظهر في الإيصال المرسل على واتساب
# للتطوير المحلي:
NEXT_PUBLIC_WEBSITE_URL=http://localhost:4001

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1


