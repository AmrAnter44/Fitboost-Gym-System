// نظام إعدادات الخدمات
model SystemSettings {
  id                    String   @id @default("singleton")
  nutritionEnabled      Boolean  @default(true)
  physiotherapyEnabled  Boolean  @default(true)
  groupClassEnabled     Boolean  @default(true)
  moreEnabled           Boolean  @default(true)
  spaEnabled            Boolean  @default(true)
  inBodyEnabled         Boolean  @default(true)
  poolEnabled           Boolean  @default(true)
  padelEnabled          Boolean  @default(true)
  assessmentEnabled     Boolean  @default(true)
  pointsEnabled         Boolean  @default(true)
  pointsPerCheckIn      Int      @default(1)
  pointsPerInvitation   Int      @default(2)
  pointsPerReferral     Int      @default(0)    // نقاط إحالة عضو جديد
  pointsPerEGPSpent     Float    @default(0.1)  // نقاط لكل جنيه يتم دفعه
  pointsPerBirthday     Int      @default(10)   // نقاط عيد الميلاد للأعضاء النشطين
  pointsValueInEGP      Float    @default(0.1)
  websiteUrl            String?  @default("https://www.xgym.website")  // رابط الموقع الإلكتروني
  showWebsiteOnReceipts Boolean  @default(false)  // عرض رابط الموقع في الإيصالات
  androidAppUrl         String?  // رابط تطبيق الأندرويد
  iosAppUrl             String?  // رابط تطبيق الـ iOS
  showAppLinksOnReceipts Boolean @default(false)  // عرض روابط التطبيق في الإيصالات
  receiptTerms          String?  @default("الساده الاعضاء حرصا منا على تقديم خدمه افضل وحفاظا على سير النظام العام للمكان بشكل مرضى يرجى الالتزام بالتعليمات الاتيه :\n\n١- الاشتراك لا يرد الا خلال ٢٤ ساعه بعد خصم قيمه الحصه\n٢- لا يجوز التمرين بخلاف الزى الرياضى\n٣- ممنوع اصطحاب الاطفال او الماكولات داخل الجيم\n٤- الاداره غير مسئوله عن المتعلقات الشخصيه")  // شروط وأحكام الإيصال

  // لوجو واسم الجيم المخصص
  gymName               String?  // اسم الجيم (يظهر في الإيصالات والسايدبار)
  gymLogo               String?  // مسار لوجو الجيم المرفوع من الأونر
  primaryColor          String?  // اللون الأساسي المخصص (hex مثل #fbe003)

  // إعدادات الجلسات المجانية
  trackFreeSessionsCost       Boolean  @default(false)  // تفعيل/تعطيل احتساب تكلفة الجلسات المجانية
  freePTSessionPrice          Float    @default(0)     // سعر جلسة PT المجانية
  freeNutritionSessionPrice   Float    @default(0)     // سعر جلسة التغذية المجانية
  freePhysioSessionPrice      Float    @default(0)     // سعر جلسة العلاج الطبيعي المجانية
  freeGroupClassSessionPrice  Float    @default(0)     // سعر جلسة الجروب كلاسيس المجانية

  // إعدادات عمولة PT/الكوتش
  ptCommissionEnabled         Boolean  @default(true)   // تفعيل/تعطيل عمولة الكوتش عند إضافة عضو
  ptCommissionAmount          Float    @default(50)     // مبلغ العمولة (جنيه)

  // إعدادات عمولة More
  moreCommissionEnabled       Boolean  @default(true)   // تفعيل/تعطيل عمولة المدرب لخدمة مزيد
  moreCommissionAmount        Float    @default(50)     // مبلغ العمولة (جنيه)

  // إعدادات عمولة Referral
  nutritionReferralEnabled    Boolean  @default(false)  // تفعيل/تعطيل Referral للتغذية
  nutritionReferralPercentage Float    @default(0)      // نسبة عمولة Referral للتغذية (%)
  physioReferralEnabled       Boolean  @default(false)  // تفعيل/تعطيل Referral للعلاج الطبيعي
  physioReferralPercentage    Float    @default(0)      // نسبة عمولة Referral للعلاج الطبيعي (%)

  // نظام بواقي الاشتراك
  remainingEnabled            Boolean  @default(false)  // تفعيل/تعطيل نظام بواقي الاشتراك (التقسيط)

  // نظام نقاط عيد الميلاد التلقائي
  lastBirthdayPointsCheck     String?  @default("1970-01-01")  // آخر تاريخ تم فيه التحقق من أعياد الميلاد (YYYY-MM-DD)

  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

// باقات الخدمات
model ServicePackage {
  id            String   @id @default(cuid())
  name          String
  serviceType   String   // 'PT', 'Nutrition', 'Physiotherapy', 'GroupClass', 'More'
  sessions      Int
  price         Float
  durationDays  Int      @default(30)  // 📅 مدة الاشتراك بالأيام (افتراضي: 30 يوم)
  moreCommission Float?  @default(0)  // 💰 عمولة المدرب لباقات مزيد (0 = استخدام الإعدادات الافتراضية)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serviceType])
  @@index([isActive])
}

// نظام النقاط - تاريخ اكتساب النقاط
model PointsHistory {
  id          String   @id @default(cuid())
  memberId    String
  points      Int      // عدد النقاط المكتسبة
  action      String   // نوع النشاط: 'check-in', 'invitation'
  description String?  // وصف اختياري
  createdAt   DateTime @default(now())

  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
  @@index([action])
}

// نظام التقييمات - تاريخ التقييمات البدنية
model AssessmentHistory {
  id          String   @id @default(cuid())
  memberId    String
  type        String   // نوع التقييم: 'weight', 'body_fat', 'muscle_mass', 'manual', etc
  value       Float?   // القيمة (وزن، نسبة دهون، إلخ)
  notes       String?  // ملاحظات أو سبب التقييم
  createdAt   DateTime @default(now())

  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
  @@index([type])
}

// جدول مواعيد الجروب كلاسيس الأسبوعية
model ClassSchedule {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0=الأحد, 1=الاثنين, 2=الثلاثاء, 3=الأربعاء, 4=الخميس, 5=الجمعة, 6=السبت
  startTime   String   // "HH:mm" e.g. "09:00"
  className   String   // نوع الكلاس e.g. "زومبا", "يوجا", "كروسفيت"
  coachName   String   // اسم الكوتش
  duration    Int      @default(60) // المدة بالدقائق
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dayOfWeek])
  @@index([isActive])
}

// قائمة المحظورين
model BannedMember {
  id         String   @id @default(cuid())
  name       String?
  phone      String?
  nationalId String?
  reason     String?
  notes      String?
  bannedBy   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phone])
  @@index([nationalId])
}

// حجوزات كلاسات اليوم
model ClassBooking {
  id              String   @id @default(cuid())
  memberId        String
  classScheduleId String   // أي كلاس محجوز
  bookingDate     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([memberId])
  @@index([bookingDate])
  @@index([classScheduleId])
  @@unique([memberId, classScheduleId, bookingDate])
}

// نظام الترخيص من Supabase
model SupabaseLicense {
  id             String   @id @default(cuid())
  gymId          String
  gymName        String
  branchId       String
  branchName     String
  systemLicense  String   // 'true', 'false', 'active'
  licenseMessage String?
  lastChecked    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([branchId])
}

// قوالب رسائل الواتساب
model WhatsAppTemplate {
  id        String   @id @default(cuid())
  title     String
  icon      String   @default("💬")
  message   String
  isCustom  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== WhatsApp Multi-Number Inbox System =====

model WhatsAppSession {
  id                String    @id @default(cuid())
  sessionIndex      Int       @unique
  label             String
  phoneNumber       String?
  status            String    @default("disconnected")
  isActive          Boolean   @default(true)
  warmupComplete    Boolean   @default(false)
  warmupStartedAt   DateTime?
  dailyMessageCount Int       @default(0)
  dailyCountResetAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  conversations WhatsAppConversation[]
  messages      WhatsAppMessage[]
  queueItems    WhatsAppQueueItem[]

  @@index([sessionIndex])
  @@index([status])
  @@index([isActive])
}

model WhatsAppConversation {
  id              String    @id @default(cuid())
  remotePhone     String    @unique
  remoteName      String?
  lastMessageAt   DateTime?
  lastMessageText String?
  status          String    @default("open")
  assignedToId    String?
  sessionId       String?
  unreadCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  session    WhatsAppSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  assignedTo Staff?           @relation("WhatsAppAssignments", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   WhatsAppMessage[]

  @@index([status])
  @@index([assignedToId])
  @@index([lastMessageAt])
  @@index([sessionId])
}

model WhatsAppMessage {
  id             String    @id @default(cuid())
  conversationId String
  sessionId      String?
  direction      String
  messageType    String    @default("text")
  content        String
  mediaUrl       String?
  whatsappMsgId  String?
  status         String    @default("pending")
  sentById       String?
  createdAt      DateTime  @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  session      WhatsAppSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([direction])
  @@index([status])
}

model WhatsAppQueueItem {
  id          String    @id @default(cuid())
  sessionId   String
  phone       String
  messageType String    @default("text")
  content     String
  mediaBase64 String?
  priority    Int       @default(5)
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  error       String?
  createdById String?
  createdAt   DateTime  @default(now())

  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status])
  @@index([scheduledAt])
  @@index([priority])
}
