# ========================================
# النظام الأساسي (Main System)
# ========================================

# SQLite Database with WAL mode for better concurrent performance
# timeout: 20 seconds for database operations
# journal_mode=WAL: Write-Ahead Logging for better concurrency
DATABASE_URL="file:./prisma/gym.db?connection_limit=1&pool_timeout=20&journal_mode=WAL"

# JWT Secret - مطلوب (minimum 32 characters)
# توليد قيمة قوية: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHARS_HEX

# Network Settings
PORT=4001
HOSTNAME=0.0.0.0

# Environment (development/production)
NODE_ENV=development

# ========================================
# Owner fallback account (OPTIONAL — recommended: create a normal user instead)
# ========================================
# يُفضَّل استخدام OWNER_PASSWORD_HASH (bcrypt) بدلاً من OWNER_PASSWORD (plaintext)
# لتوليد hash: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'YourPassword'
OWNER_EMAIL=your-owner-email-here
# OWNER_PASSWORD_HASH=$2a$12$...   # ✅ موصى به
OWNER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ========================================
# Security
# ========================================

# مفتاح مشترك بين Next.js والـ WhatsApp sidecar (Electron) لحماية الـ internal endpoints
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# في Electron production بيتولّد تلقائياً ويُحفَظ في userData
INTERNAL_API_TOKEN=REPLACE_WITH_32_BYTE_HEX

# Emergency signup (للـ bootstrap الأولي فقط — اتركه فارغاً في الإنتاج بعد إنشاء أول admin)
# EMERGENCY_SIGNUP_SECRET=
# ALLOW_EMERGENCY_SIGNUP=false

# ========================================
# Supabase Configuration (License + Error Tracking)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========================================
# GitHub Token (للتحديثات من private repo)
# ========================================
# توكن قراءة-فقط (scope: repo). لو الـ repo عام خلّيه فاضي
GH_TOKEN=
