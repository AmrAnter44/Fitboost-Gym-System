# ========================================
# النظام الأساسي (Main System)
# ========================================

# SQLite Database with WAL mode for better concurrent performance
# timeout: 20 seconds for database operations
# journal_mode=WAL: Write-Ahead Logging for better concurrency
DATABASE_URL="file:./prisma/gym.db?connection_limit=1&pool_timeout=20&journal_mode=WAL"

# JWT Secret - IMPORTANT: Change this in production!
JWT_SECRET="gym-secret-key-12345-CHANGE-THIS-IN-PRODUCTION"

# Network Settings
PORT=4001
HOSTNAME=0.0.0.0

# Environment (development/production)
NODE_ENV=development

# Public URL - غيّره للـ subdomain بتاعك
# بعد ما تخلص الإعداد، غيّره لـ:
NEXT_PUBLIC_APP_URL=http://localhost:4001
NEXT_PUBLIC_DOMAIN=system.xgym.website

# Website URL - يظهر في الإيصال المرسل على واتساب
# للتطوير المحلي:
NEXT_PUBLIC_WEBSITE_URL=http://localhost:4001
# للإنتاج:
# NEXT_PUBLIC_WEBSITE_URL=https://system.xgym.website

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ========================================
# License Configuration - إعدادات الترخيص
# ========================================

# رابط ملف الترخيص - غيّره لو عايز تستخدم ملف ترخيص مختلف
# أو امسحه خالص لو مش عايز نظام ترخيص
NEXT_PUBLIC_GITHUB_LICENSE_URL=https://raw.githubusercontent.com/AmrAnter44/systems-lock/main/xgym.json

# مفتاح الترخيص - يجب أن يطابق التوقيع في ملف JSON على GitHub
LICENSE_SIGNATURE=c78d317d35241b1dae62099a4f69b046d6x5435b

# ========================================
# Theme Customization - نظام الألوان
# ========================================

# لتغيير ألوان النظام، عدّل الملف:
# lib/theme/colors.ts

# ========================================
# Owner Account - حساب المالك الاحتياطي
# ========================================

# بيانات حساب OWNER الاحتياطي (Fallback Account)
# هذا الحساب يعمل حتى لو قاعدة البيانات معطلة
OWNER_EMAIL=fitboost
OWNER_PASSWORD=Amr#k#244#
